#!name=Myblockads
#!desc=其他软件去广告合集。
#!category=广告模块
#!date=2024-11-28 00:00:00

[Rule]
# ======= 0 ======= #
#>12306
DOMAIN,ad.12306.cn,DIRECT,extended-matching

# ======= A ======= #

# ======= B ======= #
# 百度
DOMAIN-SUFFIX,pos.baidu.com,REJECT,pre-matching
DOMAIN,mobads.baidu.com,REJECT,pre-matching

# 百度网盘
AND,((DOMAIN-SUFFIX,pan.baidu.com),(PROTOCOL,TCP)),REJECT,pre-matching

# ======= C ======= #

# ======= D ======= #
# DNS 无响应
DOMAIN,adttrackingprd.hwwt8.com,REJECT,pre-matching

# ======= G ======= #
# 广告联盟
AND,((DOMAIN-KEYWORD,mssdk),(DOMAIN-SUFFIX,zijieapi.com)),REJECT,pre-matching
AND,((DOMAIN-KEYWORD,-misc-),(DOMAIN-SUFFIX,zijieapi.com)),REJECT,pre-matching
